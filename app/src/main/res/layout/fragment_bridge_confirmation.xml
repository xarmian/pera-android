<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/confirmationTitleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/confirm_bridge_transaction"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Headline5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/sendingLabelTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/you_are_sending"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
        app:layout_constraintTop_toBottomOf="@id/confirmationTitleTextView"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/sendingAmountTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
        app:layout_constraintTop_toTopOf="@id/sendingLabelTextView"
        app:layout_constraintStart_toEndOf="@id/sendingLabelTextView"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="100.00 aVOI"/>

    <TextView
        android:id="@+id/receivingLabelTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/you_will_receive_approximately"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
        app:layout_constraintTop_toBottomOf="@id/sendingLabelTextView"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/receivingAmountTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
        app:layout_constraintTop_toTopOf="@id/receivingLabelTextView"
        app:layout_constraintStart_toEndOf="@id/receivingLabelTextView"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="99.50 VOI"/>

    <TextView
        android:id="@+id/toAccountLabelTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/to_voi_account"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
        app:layout_constraintTop_toBottomOf="@id/receivingLabelTextView"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/toAccountAddressTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
        app:layout_constraintTop_toTopOf="@id/toAccountLabelTextView"
        app:layout_constraintStart_toEndOf="@id/toAccountLabelTextView"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="VOIADDRESS..."/>

    <TextView
        android:id="@+id/bridgeTimeEstimateTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/bridge_time_estimate_message"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toBottomOf="@id/toAccountAddressTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/sendToPeraWalletButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/send_to_perawallet"
        app:layout_constraintTop_toBottomOf="@+id/bridgeTimeEstimateTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/sendToDeflyWalletButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/send_to_deflywallet"
        app:layout_constraintTop_toBottomOf="@+id/sendToPeraWalletButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/viewQrCodeButton"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/view_qr_code"
        app:layout_constraintTop_toBottomOf="@id/sendToDeflyWalletButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout> 