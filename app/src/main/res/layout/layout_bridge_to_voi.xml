<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/to_voi_account_label_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="To Voi Account"
        android:textAppearance="?attr/textAppearanceHeadline6"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/select_to_voi_account_button"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Destination Voi Account"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/to_voi_account_address_text_view"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        tools:text="Destination: YOUR_VOI_ACCOUNT_ADDRESS"
        android:textAppearance="?attr/textAppearanceCaption"/>

</LinearLayout> 